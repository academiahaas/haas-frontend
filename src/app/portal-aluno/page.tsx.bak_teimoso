                </div>
              </div>
              <div className="grid grid-cols-2 gap-2">
                <div className="bg-[#071324] border border-white/[0.02] py-2 px-1 rounded-xl text-center"><span className="text-[14px] font-mono font-black text-sky-400 block">14h</span><span className="font-sans text-[8px] font-bold tracking-tight text-slate-400 block uppercase mt-0.5">{idioma === 'PT' ? 'Imersão Absoluta' : idioma === 'ES' ? 'Inmersión Absoluta' : 'Total Immersion'}</span></div>
                <div className="bg-[#071324] border border-white/[0.02] p-3 rounded-xl text-center"><span className="text-[14px] font-mono font-black text-indigo-400 block">450</span><span className="font-sans text-[8px] font-bold tracking-tight text-slate-400 block uppercase mt-0.5">{idioma === 'PT' ? 'Vocabulário Ativado' : idioma === 'ES' ? 'Vocabulario Activado' : 'Active Vocab'}</span></div>
              </div>
            </div>
          </div>
          <div className="border-t border-white/5 pt-3.5 mt-4 flex flex-col gap-3">
            <div className="bg-amber-500/5 border border-amber-500/10 p-3 rounded-xl text-[11px] text-slate-400 leading-relaxed font-sans relative"><span className="font-bold text-amber-500 block mb-0.5">Mentora Haas:</span>{idioma === 'PT' ? 'Alpha, seu ponto fraco hoje são Phrasal Verbs. A Arena te espera para ajustar esse ponteiro.' : 'Alpha, your weak point today is Phrasal Verbs. The Arena awaits you to calibrate this vector.'}</div>
            <button onClick={() => { if(confirm(idioma === 'PT' ? 'Deseja realmente sair da conta?' : 'Are you sure you want to log out?')) { window.location.href = '/'; } }} className="w-full bg-red-950/20 hover:bg-red-950/40 text-red-400 hover:text-red-300 font-mono text-[9px] font-black py-3 uppercase tracking-widest rounded-xl border border-red-500/10 transition-all text-center active:scale-[0.99]">{idioma === 'PT' ? 'Sair da Conta' : 'Log Out'}</button>
          </div>
        </div>
        <GavetaBadges isOpen={isBadgesOpen} onClose={() => setIsBadgesOpen(false)} idioma={idioma} />
      </div>
    </div>
  );
}
