                      </div>
                      <button 
                        type="button" 
                        onClick={() => alert("Validando clique na aula ID: " + aula.id)}
                        className="py-1 px-3 bg-red-500/10 hover:bg-red-500 text-red-400 hover:text-white border border-red-500/20 text-[10px] font-black font-mono uppercase rounded-lg transition-all cursor-pointer border-none"
