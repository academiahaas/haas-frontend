"use client";
import React, { useState, useEffect, useRef } from "react";
import { Mic, Disc, CheckCircle, Loader2, Star } from "lucide-react";

interface MioloRoleplayProps {
  onSelectCorrect?: () => void;
  onSelectWrong?: () => void;
  unidadeAtiva?: string;
}

export default function MioloRoleplay({ onSelectCorrect, onSelectWrong, unidadeAtiva }: MioloRoleplayProps) {
  const [flowState, setFlowState] = useState<"IA_SPEAKING" | "USER_TURN" | "RECORDING" | "PLAYBACK" | "DONE">("IA_SPEAKING");
  const [phraseIA, setPhraseIA] = useState("Carregando pergunta da IA...");
  const [phraseUserExpected, setPhraseUserExpected] = useState("");
  const [transcricaoAluno, setTranscricaoAluno] = useState("");
  const [scoreFinal, setScoreFinal] = useState(0);
  const [carregando, setCarregando] = useState(true);

  // Refs de controle de áudio e reconhecimento de fala nativo
  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const streamRef = useRef<MediaStream | null>(null);
  const audioChunksRef = useRef<Blob[]>([]);
  const recognitionRef = useRef<any>(null);
  const [audioUrl, setAudioUrl] = useState<string | null>(null);

  // Algoritmo matemático real de cálculo de similaridade (Levenshtein) roubado do Shadowing
  const calcularSimilaridadeReal = (s1: string, s2: string): number => {
    const n1 = s1.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()]/g, "").trim();
    const n2 = s2.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()]/g, "").trim();
    if (n1 === n2) return 100;
    if (!n1 || !n2) return 0;
    
    const arr = Array(n1.length + 1).fill(null).map(() => Array(n2.length + 1).fill(null));
    for (let i = 0; i <= n1.length; i++) arr[i][0] = i;
    for (let j = 0; j <= n2.length; j++) arr[0][j] = j;

    for (let i = 1; i <= n1.length; i++) {
      for (let j = 1; j <= n2.length; j++) {
        const cost = n1[i - 1] === n2[j - 1] ? 0 : 1;
        arr[i][j] = Math.min(arr[i - 1][j] + 1, arr[i][j - 1] + 1, arr[i - 1][j - 1] + cost);
      }
    }
    const distance = arr[n1.length][n2.length];
    const maxLength = Math.max(n1.length, n2.length);
    return Math.round(((maxLength - distance) / maxLength) * 100);
  };

  const limparPerguntaDeLacunas = (textoSujo: string): string => {
    if (!textoSujo) return "";
    let limpo = textoSujo
      .replace(/_{2,}/g, "")
      .replace(/-{2,}/g, "")
      .replace(/\[\.{3}\]/g, "")
      .replace(/\[\s*\]/g, "")
      .replace(/\([a-zA-ZáàâãéèêíïóôõöúçñÁÀÂÃÉÈÊÍÏÓÔÕÖÚÇÑ\s]+\)/g, "")
      .replace(/\s+/g, " ")
      .trim();

    if (limpo.length < 5) {
      limpo = "Como você prefere praticar a conversação em português hoje?";
    }
    return limpo;
  };

  useEffect(() => {
    async function carregarEFiltrarTipo1() {
      try {
        setCarregando(true);
        const key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpkcHB4Zm9rZmhxanVkd2Z3Y2tkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5Mjk2NzgsImV4cCI6MjA5NTUwNTY3OH0.1zkCP7WUv1QJvWu35jQSRByFp-CSxD-Zfj6yKJysGIU";
        const url = "https://jdppxfokfhqjudwfwckd.supabase.co/rest/v1/exercises?activity_type=eq.1&limit=1";
        
        const res = await fetch(url, { headers: { "apikey": key, "Authorization": "Bearer " + key } });
        const dados = await res.json();
        
        if (dados && dados.length > 0) {
          const exe = dados[0];
          const perguntaLimpa = limparPerguntaDeLacunas(exe.reading_text || exe.context || "");
          
          setPhraseIA(perguntaLimpa);
          // Armazena a resposta ideal esperada pelo banco para fazer o cruzamento de validação
          setPhraseUserExpected(exe.correct_answer || "");
          setFlowState("IA_SPEAKING");
        }
      } catch (err) {
        console.error("Erro ao sincronizar Tipo 1 para Conversação:", err);
      } finally {
        setCarregando(false);
      }
    }
    carregarEFiltrarTipo1();
  }, [unidadeAtiva]);

  useEffect(() => {
    if (flowState === "IA_SPEAKING" && !carregando) {
      const timer = setTimeout(() => { setFlowState("USER_TURN"); }, 2500);
      return () => clearTimeout(timer);
    }
  }, [flowState, carregando]);

  const iniciarGravacaoReal = () => {
    audioChunksRef.current = [];
    setTranscricaoAluno("");
    
    if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
      navigator.mediaDevices.getUserMedia({ audio: true })
        .then((stream) => {
          streamRef.current = stream;
          const recorder = new MediaRecorder(stream);
          mediaRecorderRef.current = recorder;
          
          recorder.ondataavailable = (e) => {
            if (e.data && e.data.size > 0) audioChunksRef.current.push(e.data);
          };
          
          recorder.onstop = () => {
            const audioBlob = new Blob(audioChunksRef.current, { type: 'audio/wav' });
            setAudioUrl(URL.createObjectURL(audioBlob));
            setFlowState('PLAYBACK');
          };

          const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
          if (SpeechRecognition) {
            const recognition = new SpeechRecognition();
            recognition.lang = 'pt-BR';
            recognition.continuous = true;
            recognition.interimResults = false;
            
            recognition.onresult = (event: any) => {
              let acumulado = "";
              for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) acumulado += event.results[i][0].transcript + " ";
              }
              if (acumulado) setTranscricaoAluno((prev) => (prev + " " + acumulado).trim());
            };
            
            recognitionRef.current = recognition;
            recognition.start();
          }
          
          recorder.start();
          setFlowState('RECORDING');
        }).catch((err) => console.error("Erro microfone:", err));
    }
  };

  const pararGravacaoReal = () => {
    if (recognitionRef.current) {
      try { recognitionRef.current.stop(); } catch (e) {}
    }
    if (mediaRecorderRef.current && mediaRecorderRef.current.state === 'recording') {
      mediaRecorderRef.current.stop();
    }
    if (streamRef.current) {
      streamRef.current.getTracks().forEach(track => track.stop());
    }
  };

  const processarAvaliacaoFinal = () => {
    // Se houver uma resposta modelo cadastrada, compara com ela, senão valida com base em ter falado algo
    const alvoComparacao = phraseUserExpected || transcricaoAluno;
    const matchScore = calcularSimilaridadeReal(alvoComparacao, transcricaoAluno);
    
    setScoreFinal(matchScore);
    setFlowState('DONE');
    
    // Se o aluno obteve mais que 40% de acerto nas palavras chaves faladas, aprova o exercício na arena
    if (matchScore >= 40) {
      if (onSelectCorrect) onSelectCorrect();
    } else {
      if (onSelectWrong) onSelectWrong();
    }
  };

  if (carregando) {
    return (
      <div className="w-full text-center py-12 text-cyan-400 font-bold animate-pulse text-xs uppercase tracking-widest">
        Inicializando Transcritor de Conversação...
      </div>
    );
  }

  return (
    <div className="w-full h-full flex flex-col justify-between items-stretch text-left font-sans flex-1 min-h-0 gap-5 overflow-hidden">
      
      {/* Balão de Pergunta IA */}
      <div className="bg-[#0c192e] border border-white/[0.04] p-5 rounded-2xl flex items-start transition-all">
        <div className="space-y-1 flex-1">
          <span className="text-[10px] font-bold uppercase tracking-wider text-cyan-400/60">Perguntas da IA</span>
          <p className="text-[15px] text-slate-200 font-medium leading-relaxed">{phraseIA}</p>
        </div>
      </div>

      {/* Box de Feedback da Transcrição em Tempo Real */}
      {(flowState === 'PLAYBACK' || flowState === 'DONE' || transcricaoAluno) && (
        <div className="bg-[#070e1b] border border-dashed border-white/[0.06] p-4 rounded-xl max-h-[100px] overflow-y-auto">
          <span className="text-[10px] font-bold text-slate-400 uppercase tracking-widest block mb-1">O que você falou:</span>
          <p className="text-xs text-cyan-300 italic">"{transcricaoAluno || "Ouvindo som ambiente..."}"</p>
        </div>
      )}

      {/* Painel do Gravador */}
      <div className="flex-1 flex flex-col items-center justify-center gap-4 bg-[#060f1e]/40 rounded-2xl border border-dashed border-white/[0.04] p-6 min-h-[160px]">
        {flowState === "IA_SPEAKING" && (
          <p className="text-xs font-semibold text-slate-500 uppercase tracking-widest animate-pulse">A IA está gerando o contexto...</p>
        )}
        {flowState === "USER_TURN" && (
          <p className="text-xs font-semibold text-cyan-400 uppercase tracking-widest">Toque no microfone e responda</p>
        )}
        {flowState === "RECORDING" && (
          <p className="text-xs font-semibold text-rose-500 uppercase tracking-widest animate-pulse flex items-center gap-1.5">
            <Disc size={14} className="animate-spin" /> Transcrevendo Fala em Tempo Real...
          </p>
        )}
        {flowState === "PLAYBACK" && (
          <p className="text-xs font-semibold text-amber-400 uppercase tracking-widest">Áudio capturado! Pronto para validar</p>
        )}
        {flowState === "DONE" && (
          <div className="w-full flex flex-col items-center gap-2 animate-fade-in px-4">
            <span className="text-xs font-black tracking-widest text-[#00E676] uppercase flex items-center gap-1">
              <Star size={14} /> ANALISADO: {scoreFinal}% MATCH
            </span>
            <div className="w-full max-w-[200px] bg-slate-800 h-2 rounded-full overflow-hidden">
              <div className="bg-gradient-to-r from-cyan-500 to-emerald-400 h-full transition-all duration-500" style={{ width: `${scoreFinal}%` }} />
            </div>
          </div>
        )}

        {/* Botão Dinâmico de Captura */}
        {flowState === 'PLAYBACK' ? (
          <div className="w-full flex gap-3 max-w-sm shrink-0">
            <button onClick={() => { setFlowState('USER_TURN'); setAudioUrl(null); setTranscricaoAluno(""); }} className="flex-1 py-3 bg-slate-800 text-slate-300 rounded-xl font-bold text-xs uppercase tracking-wider cursor-pointer active:scale-95 transition-all">Refazer</button>
            <button onClick={processarAvaliacaoFinal} className="flex-1 py-3 bg-gradient-to-r from-emerald-600 to-emerald-700 text-white rounded-xl font-bold text-xs uppercase tracking-wider cursor-pointer active:scale-95 transition-all shadow-md">Avaliar Resposta</button>
          </div>
        ) : (
          <button
            onClick={flowState === 'RECORDING' ? pararGravacaoReal : iniciarGravacaoReal}
            disabled={flowState === "IA_SPEAKING" || flowState === "DONE"}
            className={`w-20 h-20 rounded-full flex items-center justify-center transition-all cursor-pointer border-none shadow-lg active:scale-90 disabled:opacity-20 disabled:cursor-not-allowed ${
              flowState === "RECORDING" 
                ? "bg-rose-600 shadow-rose-950/50 animate-pulse" 
                : "bg-gradient-to-tr from-cyan-600 to-cyan-500 shadow-cyan-950/50"
            }`}
          >
            <Mic size={28} className="text-white" />
          </button>
        )}
      </div>

    </div>
  );
}
