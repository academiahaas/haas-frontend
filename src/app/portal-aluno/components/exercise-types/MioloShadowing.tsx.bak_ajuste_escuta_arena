'use client';
import React, { useState, useEffect, useRef } from 'react';
import { Mic, Volume2, Play, CheckCircle2, Square, RefreshCw, Star, AlertTriangle } from 'lucide-react';

interface MioloShadowingProps {
  onSelectCorrect?: () => void;
  onSelectWrong?: () => void;
  unidadeAtiva?: string;
}

export default function MioloShadowing({ onSelectCorrect, onSelectWrong, unidadeAtiva }: MioloShadowingProps) {
  const [faseVoz, setFaseVoz] = useState<'IDLE' | 'RECORDING' | 'PLAYBACK' | 'DONE'>('IDLE');
  const [referencePhrase, setReferencePhrase] = useState<string | null>(null);
  const [erroBanco, setErroBanco] = useState<string | null>(null);
  const [scoreFinal, setScoreFinal] = useState<number>(0);
  const [transcricaoAluno, setTranscricaoAluno] = useState<string>("");
  
  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const audioChunksRef = useRef<Blob[]>([]);
  const [audioUrl, setAudioUrl] = useState<string | null>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const streamRef = useRef<MediaStream | null>(null);
  const recognitionRef = useRef<any>(null);

  useEffect(() => {
    async function carregarShadowingDoBanco() {
      try {
        const nomeUnidade = unidadeAtiva || "O Labirinto dos Passados Irregulares";
        const url = `https://jdppxfokfhqjudwfwckd.supabase.co/rest/v1/exercises?unit=eq.${encodeURIComponent(nomeUnidade)}&activity_type=eq.8`;
        const key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpkcHB4Zm9rZmhxanVkd2Z3Y2tkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5Mjk2NzgsImV4cCI6MjA5NTUwNTY3OH0.1zkCP7WUv1QJvWu35jQSRByFp-CSxD-Zfj6yKJysGIU";
        
        const res = await fetch(url, { headers: { "apikey": key, "Authorization": "Bearer " + key } });
        if (!res.ok) throw new Error(`HTTP status ${res.status}`);
        
        const dados = await res.json();
        
        if (dados && dados.length > 0) {
          setReferencePhrase(dados[0].correct_answer || "Frase sem conteúdo no cadastro.");
          setErroBanco(null);
        } else {
          setReferencePhrase(null);
          setErroBanco(`Nenhum exercício do tipo Shadowing (activity_type 8) encontrado para a unidade "${nomeUnidade}" no Supabase.`);
        }
      } catch (err: any) {
        setReferencePhrase(null);
        setErroBanco(`Falha crítica de comunicação com o Supabase: ${err.message || err}`);
      }
    }
    carregarShadowingDoBanco();
  }, [unidadeAtiva]);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = faseVoz === 'RECORDING' ? '#ef4444' : '#22d3ee';
    for (let i = 0; i < 50; i++) {
      const h = faseVoz === 'RECORDING' ? Math.random() * 16 + 4 : Math.sin(i * 0.4) * 6 + 10;
      ctx.fillRect(i * 6, (24 - h) / 2, 3, h);
    }
  }, [faseVoz]);

  const playNativo = () => {
    if (referencePhrase && typeof window !== 'undefined' && 'speechSynthesis' in window) {
      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(referencePhrase);
      utterance.lang = 'pt-BR';
      utterance.rate = 0.90;
      window.speechSynthesis.speak(utterance);
    }
  };

  const normalizarTexto = (txt: string) => {
    return txt
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?]/g, "")
      .replace(/\s+/g, " ")
      .trim();
  };

  const calcularSimilaridadeReal = (s1: string, s2: string) => {
    const n1 = normalizarTexto(s1);
    const n2 = normalizarTexto(s2);
    if (n1 === n2) return 100;
    if (n1.length === 0 || n2.length === 0) return 0;

    const arr = [];
    for (let i = 0; i <= n1.length; i++) arr[i] = [i];
    for (let j = 0; j <= n2.length; j++) arr[0][j] = j;

    for (let i = 1; i <= n1.length; i++) {
      for (let j = 1; j <= n2.length; j++) {
        const cost = n1[i - 1] === n2[j - 1] ? 0 : 1;
        arr[i][j] = Math.min(arr[i - 1][j] + 1, arr[i][j - 1] + 1, arr[i - 1][j - 1] + cost);
      }
    }
    const distance = arr[n1.length][n2.length];
    const maxLength = Math.max(n1.length, n2.length);
    return Math.round(((maxLength - distance) / maxLength) * 100);
  };

  const calcularPontuacaoCompetencia = (matchPercent: number): number => {
    return matchPercent;
  };

  const salvarPontuacaoNoBanco = async (pontosFinais: number) => {
    try {
      const urlCompetencias = `https://jdppxfokfwqjudwfwckd.supabase.co/rest/v1/user_competencias`;
      const key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpkcHB4Zm9rZmhxanVkd2Z3Y2tkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5Mjk2NzgsImV4cCI6MjA5NTUwNTY3OH0.1zkCP7WUv1QJvWu35jQSRByFp-CSxD-Zfj6yKJysGIU";
      
      const payload = {
        habla: pontosFinais,
        updated_at: new Date().toISOString()
      };

      await fetch(urlCompetencias, {
        method: 'POST',
        headers: {
          "apikey": key,
          "Authorization": "Bearer " + key,
          "Content-Type": "application/json",
          "Prefer": "resolution=merge-duplicates"
        },
        body: JSON.stringify(payload)
      });
      console.log(`Pontuação salva.`);
    } catch (error) {
      console.error("Erro ao sincronizar competência habla:", error);
    }
  };

  const iniciarGravacao = () => {
    if (erroBanco) return;
    audioChunksRef.current = [];
    setTranscricaoAluno("");
    
    if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
      navigator.mediaDevices.getUserMedia({ audio: true })
        .then((stream) => {
          streamRef.current = stream;
          const recorder = new MediaRecorder(stream);
          mediaRecorderRef.current = recorder;
          
          recorder.ondataavailable = (e) => {
            if (e.data && e.data.size > 0) audioChunksRef.current.push(e.data);
          };

          recorder.onstop = () => {
            const audioBlob = new Blob(audioChunksRef.current, { type: 'audio/wav' });
            setAudioUrl(URL.createObjectURL(audioBlob));
            setFaseVoz('PLAYBACK');
          };

          const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
          if (SpeechRecognition) {
            const recognition = new SpeechRecognition();
            recognition.lang = 'pt-BR';
            recognition.continuous = true;
            recognition.interimResults = false;

            recognition.onresult = (event: any) => {
              let acumulado = "";
              for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                  acumulado += event.results[i][0].transcript + " ";
                }
              }
              if (acumulado) {
                setTranscricaoAluno((prev) => (prev + " " + acumulado).trim());
              }
            };

            recognitionRef.current = recognition;
            recognition.start();
          }

          recorder.start();
          setFaseVoz('RECORDING');
        })
        .catch((err) => {
          console.error("Erro ao acessar microfone:", err);
        });
    }
  };

  const pararGravacao = () => {
    if (recognitionRef.current) {
      try { recognitionRef.current.stop(); } catch (e) {}
    }
    if (mediaRecorderRef.current && mediaRecorderRef.current.state === 'recording') {
      mediaRecorderRef.current.stop();
    }
    if (streamRef.current) {
      streamRef.current.getTracks().forEach(track => track.stop());
    }
  };

  const playAudioAlunoReal = () => {
    if (audioUrl) {
      const audio = new Audio(audioUrl);
      audio.play().catch((e) => console.error("Erro ao reproduzir:", e));
    }
  };

  const handleAvaliarMotorReal = () => {
    if (!referencePhrase) return;
    const notaCalculada = calcularSimilaridadeReal(referencePhrase, transcricaoAluno);
    setScoreFinal(notaCalculada);
    setFaseVoz('DONE');
    
    const pontosFinaisCalculados = calcularPontuacaoCompetencia(notaCalculada);
    salvarPontuacaoNoBanco(pontosFinaisCalculados);

    if (onSelectCorrect) onSelectCorrect();
  };

  return (
    <div className="w-full h-full flex flex-col justify-between items-stretch text-left font-mono flex-1 min-h-0 gap-3 overflow-hidden">
      
      <div className="flex items-center gap-3 shrink-0 bg-[#0c192e] p-3 rounded-xl border border-white/[0.04]">
        <button 
          onClick={playNativo} 
          disabled={!!erroBanco}
          className="p-2.5 bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-500/30 text-cyan-400 rounded-xl cursor-pointer transition-all shrink-0 active:scale-95 disabled:opacity-30 disabled:cursor-not-allowed"
        >
          <Volume2 size={18} />
        </button>
        <span className="text-[11px] font-bold text-slate-300 leading-normal">
          {erroBanco ? "Erro de sincronização pendente com o banco." : "Ouça o nativo, grave sua imitação, escute e refaça se precisar antes de avaliar."}
        </span>
      </div>

      <div className="bg-[#0c192e] border border-white/[0.04] rounded-xl py-4 px-4 text-center font-sans text-[clamp(13px,3.6vw,15px)] font-semibold leading-relaxed flex-1 min-h-0 flex items-center justify-center overflow-y-auto">
        <div className="w-full block h-auto py-1">
          {erroBanco ? (
            <div className="flex flex-col items-center justify-center gap-2 text-rose-400 p-2 text-xs font-mono">
              <AlertTriangle size={24} className="text-rose-500 animate-bounce" />
              <span className="font-bold text-sm uppercase tracking-wider">Aviso de Cadastro:</span>
              <p className="max-w-md text-center opacity-90 leading-normal">{erroBanco}</p>
            </div>
          ) : referencePhrase ? (
            <span className="text-slate-200">"{referencePhrase}"</span>
          ) : (
            <span className="text-slate-400 animate-pulse">Conectando ao Supabase...</span>
          )}
        </div>
      </div>

      <div className="w-full bg-[#070d19] border border-white/[0.02] rounded-xl py-2 px-4 flex justify-center items-center h-12 shrink-0 overflow-hidden">
        {faseVoz === 'DONE' ? (
          <div className="w-full flex items-center justify-between gap-4 font-sans animate-fade-in">
            <span className="text-cyan-400 font-bold text-xs uppercase tracking-wider flex items-center gap-1"><Star size={14} /> Score Real:</span>
            <div className="flex-1 max-w-[120px] bg-slate-800 h-2 rounded-full overflow-hidden"><div className="bg-cyan-500 h-full transition-all duration-1000" style={{ width: `${scoreFinal}%` }} /></div>
            <span className="text-[#00E676] font-black text-sm">{scoreFinal}% MATCH</span>
          </div>
        ) : (
          <canvas ref={canvasRef} width="300" height="24" className="w-full max-w-[300px]" />
        )}
      </div>

      <div className="w-full shrink-0 flex flex-col gap-2">
        {faseVoz === 'PLAYBACK' ? (
          <div className="w-full flex flex-col gap-2">
            <div className="w-full flex gap-2">
              <button onClick={playAudioAlunoReal} className="flex-1 py-3 bg-[#0c192e] border border-cyan-500/30 text-cyan-400 rounded-xl font-black text-xs uppercase tracking-widest cursor-pointer active:scale-95">
                Escutar Minha Voz
              </button>
              <button onClick={() => { setFaseVoz('IDLE'); setAudioUrl(null); setTranscricaoAluno(""); }} className="py-3 px-4 bg-slate-800 text-slate-300 rounded-xl font-black text-xs uppercase tracking-widest cursor-pointer active:scale-95">
                Refazer
              </button>
            </div>
            <button onClick={handleAvaliarMotorReal} className="w-full py-3.5 bg-gradient-to-r from-emerald-600 to-emerald-700 text-white rounded-xl font-black text-xs uppercase tracking-widest cursor-pointer shadow-md active:scale-95">
              Avaliar Pronúncia
            </button>
          </div>
        ) : (
          <button
            onClick={faseVoz === 'IDLE' ? iniciarGravacao : pararGravacao}
            disabled={faseVoz === 'DONE' || !!erroBanco}
            className={`w-full py-3.5 rounded-xl font-black text-xs uppercase tracking-widest cursor-pointer border-none active:scale-95 ${
              erroBanco ? 'bg-slate-800 text-slate-500 cursor-not-allowed opacity-50' :
              faseVoz === 'RECORDING' ? 'bg-red-600 text-white animate-pulse' : 
              faseVoz === 'DONE' ? 'bg-[#00E676] text-slate-950 font-black' : 
              'bg-gradient-to-r from-cyan-600 to-cyan-700 text-white shadow-md'
            }`}
          >
            {erroBanco ? 'Bloqueado por Erro de Banco' : 
             faseVoz === 'IDLE' ? 'Iniciar Gravação' : 
             faseVoz === 'RECORDING' ? 'Parar Gravação' : 'Métrica Concluída'}
          </button>
        )}
      </div>
    </div>
  );
}
