"use client";
import { supabase } from '@/lib/supabase';
import React, { useState, useEffect } from "react";

interface MioloProps {
  onSelectionChange?: (hasItems: boolean) => void;
  onValidateResult?: (isCorrect: boolean) => void;
  status?: "IDLE" | "CORRECT" | "WRONG";
  unidadeAtiva?: string;
}

export default function MioloMultiplaEscolha({ 
  onSelectionChange,
  onValidateResult,
  status = "IDLE",
  unidadeAtiva
}: MioloProps) {
  const [selecionado, setSelecionado] = useState<string | null>(null);
  const [options, setOptions] = useState<string[]>([]);
  const [correctOption, setCorrectOption] = useState<string>("");
  const [pergunta, setPergunta] = useState<string>("Carregando enunciado...");

  useEffect(() => {
    async function carregarMultiplaEscolhaDoBanco() {
      try {
        // Fallback para a unidade ativa correta caso venha indefinida da Arena
        const nomeUnidade = unidadeAtiva || 'O Labirinto dos Passados Irregulares';
        
        // Puxando os dados direto da Central Cliente Oficial filtrando pelo Tipo 3
        const { data: dados, error } = await supabase
          .from('exercises')
          .select('*')
          .eq('unit', nomeUnidade)
          .eq('activity_type', 3);

        if (error) throw error;

        if (dados && dados.length > 0) {
          const exe = dados[0];
          
          // Correção: Salvando o enunciado que estava oculto
          setPergunta(exe.reading_text || "Selecione a resposta correta:");
          setCorrectOption(exe.correct_answer || "");

          let erradas = [];
          if (exe.alternative_options) {
            if (Array.isArray(exe.alternative_options)) {
              erradas = exe.alternative_options;
            } else if (typeof exe.alternative_options === 'string') {
              try {
                erradas = JSON.parse(exe.alternative_options);
              } catch (e) {
                erradas = exe.alternative_options.split(',').map((s) => s.trim());
              }
            }
          }

          const todasOpcoes = exe.correct_answer 
            ? Array.from(new Set([exe.correct_answer, ...erradas]))
            : erradas;

          setOptions(todasOpcoes);
        }
      } catch (err) {
        console.error("Erro na Central Cliente (Múltipla Escolha):", err);
      }
    }
    carregarMultiplaEscolhaDoBanco();
  }, [unidadeAtiva]);

  useEffect(() => {
    if (status === "IDLE") setSelecionado(null);
  }, [status]);

  const handleSelect = (opcao: string) => {
    if (status !== "IDLE") return; 
    try {
      const AudioContext = window.AudioContext || (window as any).webkitAudioContext;
      if (AudioContext) {
        const ctx = new AudioContext();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = "sine"; osc.frequency.setValueAtTime(1020, ctx.currentTime);
        gain.gain.setValueAtTime(0.05, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.03);
        osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.03);
      }
    } catch (e) {}
    setSelecionado(opcao);
    if (onSelectionChange) onSelectionChange(true);
    
    // Conexão direta com o validador da ArenaQuiz
    if (onValidateResult) {
      onValidateResult(opcao === correctOption);
    }
  };

  return (
    <div className="flex flex-col items-stretch justify-between w-full h-full font-mono text-left animate-fade-in flex-1 min-h-0 gap-3">
      {/* Caixa do Enunciado inserida mantendo o padrão visual */}
      <div className="mb-1 p-4 bg-[#07111e] border border-white/[0.02] rounded-xl">
        <p className="text-sm md:text-base font-sans font-semibold text-[#F8FAFC]">
          {pergunta}
        </p>
      </div>

      {options.map((opcao, idx) => {
        const isThisSelected = selecionado === opcao;
        let customStyle = "bg-[#0c192e] border-white/[0.04] text-[#F8FAFC] shadow-[0_6px_18px_rgba(0,0,0,0.15)] hover:brightness-[1.03] hover:border-[#f59e0b]/40 hover:brightness-[1.08] hover:shadow-lg";
        
        if (isThisSelected) {
          if (status === "CORRECT") {
            customStyle = "bg-gradient-to-b from-[#FF8A2B] to-[#FF7420] border-[#FFB478]/35 text-white shadow-[0_0_24px_rgba(255,160,70,0.35)]";
          } else if (status === "WRONG") {
            customStyle = "bg-[#6B2B2B] border-red-500/20 text-[#F8FAFC]";
          } else {
            customStyle = "bg-gradient-to-b from-[#FF8A2B] to-[#FF7420] border-[#FFB478]/35 text-white shadow-[0_10px_32px_rgba(255,120,40,0.22)] active:scale-[0.98]";
          }
        }
        return (
          <button
            key={idx}
            disabled={status !== "IDLE"}
            onClick={() => handleSelect(opcao)}
            className={"w-full flex items-center justify-start text-left gap-3 p-2.5 md:p-4 rounded-xl font-sans font-medium text-xs md:text-sm leading-normal border cursor-pointer transition-all duration-180 ease-out " + customStyle}
          >
            {opcao}
          </button>
        );
      })}
    </div>
  );
}
