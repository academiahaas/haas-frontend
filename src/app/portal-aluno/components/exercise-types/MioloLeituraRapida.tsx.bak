'use client';
import React, { useState, useEffect, useRef } from 'react';
import { Timer, FileText, CheckCircle2 } from 'lucide-react';
import { supabase } from '@/lib/supabase';

interface MioloLeituraRapidaProps {
  onSelectionChange?: (hasItems: boolean) => void;
  onValidateResult?: (isCorrect: boolean) => void;
  status?: 'IDLE' | 'CORRECT' | 'WRONG';
  unidadeAtiva?: string;
}

export default function MioloLeituraRapida({
  onSelectionChange,
  onValidateResult,
  status = 'IDLE',
  unidadeAtiva
}: MioloLeituraRapidaProps) {
  const [microtexto, setMicrotexto] = useState<string>("");
  const [gabaritoCorreto, setGabaritoCorreto] = useState<string>("");
  const [opcoesAlternativas, setOpcoesAlternativas] = useState<string[]>([]);
  const [opcaoSelecionada, setOpcaoSelecionada] = useState<string | null>(null);

  const [timeLeft, setTimeLeft] = useState(15);
  const [fase, setFase] = useState<'LEITURA' | 'PERGUNTA'>('LEITURA');
  const timerRef = useRef<any>(null);

  useEffect(() => {
    async function carregarDadosDaCentral() {
      try {
        const nomeUnidade = unidadeAtiva || "O Labirinto dos Passados Irregulares";

        const { data: dados, error } = await supabase
          .from('exercises')
          .select('*')
          .eq('unit', nomeUnidade)
          .eq('activity_type', 6);

        if (error) throw error;

        if (dados && dados.length > 0) {
          const exe = dados[0];
          const respostaCerta = (exe.correct_answer || "").trim();
          
          setMicrotexto(exe.reading_text || "");
          setGabaritoCorreto(respostaCerta);
          setOpcaoSelecionada(null);
          setFase('LEITURA');
          setTimeLeft(15);

          let opcoesMapeadas: string[] = [];

          if (exe.alternative_options) {
            try {
              opcoesMapeadas = typeof exe.alternative_options === 'string'
                ? JSON.parse(exe.alternative_options)
                : exe.alternative_options;
            } catch (e) {
              opcoesMapeadas = [];
            }
          }

          // FALLBACK COERENTE: Se o banco não trouxer alternativas, gera distratores baseados no próprio texto
          if (!Array.isArray(opcoesMapeadas) || opcoesMapeadas.length === 0) {
            if (respostaCerta.includes("banco")) {
              opcoesMapeadas = [
                respostaCerta,
                "Ontem foi um dia calmo. Eu fiquei em casa descansando e não precisei resolver nenhuma pendência na rua.",
                "Ontem eu fui viajar de avião para São Paulo e passei o dia inteiro parado no trânsito a caminho do hotel.",
                "Ontem eu fui ao centro da cidade apenas para almoçar com o meu irmão e voltamos cedo para casa de trem."
              ];
            } else {
              // Fallback genérico de segurança caso mude o texto da unidade
              opcoesMapeadas = [
                respostaCerta,
                "A alternativa selecionada apresenta uma interpretação incorreta dos fatos narrados no microtexto.",
                "O relato descreve acontecimentos ocorridos de forma totalmente inversa ao longo do período planejado.",
                "A persistência em rotinas antigas impediu a conclusão bem-sucedida das tarefas diárias descritas."
              ];
            }
          }

          const opcoesFinais = Array.from(new Set(opcoesMapeadas.map(str => String(str).trim())));
          setOpcoesAlternativas(opcoesFinais.sort(() => Math.random() - 0.5));
        }
      } catch (err) {
        console.error("Erro ao processar Leitura Veloz:", err);
      }
    }
    carregarDadosDaCentral();
  }, [unidadeAtiva]);

  useEffect(() => {
    if (status !== 'IDLE') {
      clearInterval(timerRef.current);
      return;
    }
    timerRef.current = setInterval(() => {
      setTimeLeft((prev) => {
        if (prev <= 1) {
          if (fase === 'LEITURA') {
            setFase('PERGUNTA');
            return 25;
          }
          clearInterval(timerRef.current);
          return 0;
        }
        return prev - 1;
      });
    }, 1000);
    return () => clearInterval(timerRef.current);
  }, [fase, status]);

  const handleMarcarOpcao = (opcao: string) => {
    if (status === 'CORRECT') return;
    setOpcaoSelecionada(opcao);
    if (onSelectionChange) onSelectionChange(true);

    const acertou = opcao.trim().toLowerCase() === gabaritoCorreto.toLowerCase();
    if (onValidateResult) onValidateResult(acertou);
  };

  return (
    <div className="w-full h-full flex flex-col justify-between items-stretch text-left animate-fade-in font-mono flex-1 min-h-0 gap-4">
      
      {/* HEADER COERENTE COM O SEU SISTEMA */}
      <div className="flex items-center justify-between shrink-0 bg-[#070d19]/60 p-3 rounded-xl border border-white/[0.02]">
        <div className="px-4 py-2 bg-[#0c192e] border border-cyan-500/20 text-cyan-400 font-black text-xs uppercase tracking-wider rounded-xl flex items-center gap-2">
          <FileText size={14} />
          <span>LEITURA VELOZ</span>
        </div>
        <div className={`flex items-center gap-1.5 px-3 py-1 rounded-lg border font-black text-xs ${
          timeLeft <= 5 ? 'text-red-500 border-red-500/20 bg-red-500/5 animate-pulse' : 'text-[#f59e0b] border-[#f59e0b]/20 bg-[#f59e0b]/5'
        }`}>
          <Timer size={14} />
          <span>{timeLeft}s</span>
        </div>
      </div>

      {/* ÁREA DE CONTEÚDO */}
      <div className="bg-[#0c192e] border border-white/[0.04] rounded-xl p-5 flex-1 min-h-0 flex flex-col items-center justify-center overflow-y-auto w-full">
        {fase === 'LEITURA' ? (
          <p className="font-sans text-slate-200 text-justify leading-relaxed text-[clamp(13px,3.8vw,15px)] select-none w-full">
            {microtexto || "Carregando texto de leitura..."}
          </p>
        ) : (
          <div className="w-full flex flex-col gap-3 h-full justify-center">
            <span className="text-[10px] font-black text-cyan-400 uppercase tracking-widest text-center block mb-2">
              SELECIONE A ALTERNATIVA CORRETA BASEADA NO TEXTO LIDO:
            </span>
            
            <div className="w-full flex flex-col gap-2 overflow-y-auto max-h-[260px] pr-1">
              {opcoesAlternativas.map((opcao, index) => {
                const isSelected = opcaoSelecionada === opcao;
                return (
                  <button
                    key={index}
                    disabled={status === 'CORRECT'}
                    onClick={() => handleMarcarOpcao(opcao)}
                    className={`w-full p-3.5 text-left font-sans text-xs font-semibold rounded-xl border transition-all duration-150 cursor-pointer flex items-center justify-between gap-3 active:scale-[0.99] ${
                      isSelected
                        ? 'bg-cyan-500/10 border-cyan-400 text-cyan-300 shadow-[0_0_12px_rgba(34,211,238,0.1)]'
                        : 'bg-[#070d19] hover:bg-[#0c192e] border-white/[0.05] text-slate-300'
                    }`}
                  >
                    <span className="leading-relaxed">{opcao}</span>
                    {isSelected && <CheckCircle2 size={14} className="text-cyan-400 shrink-0" />}
                  </button>
                );
              })}
            </div>
          </div>
        )}
      </div>

      {fase === 'LEITURA' && (
        <div className="w-full shrink-0">
          <button
            onClick={() => { setFase('PERGUNTA'); setTimeLeft(25); }}
            className="w-full py-3.5 bg-gradient-to-r from-cyan-600 to-cyan-700 text-white font-black text-xs uppercase tracking-widest rounded-xl shadow-md cursor-pointer transition-all active:scale-95 text-center"
          >
            Terminei de ler! Responder agora
          </button>
        </div>
      )}

    </div>
  );
}
