'use client';
import { supabase } from '@/lib/supabase';
import React, { useState, useEffect } from 'react';
import { CheckCircle, XCircle, Sparkles, Send, RefreshCw, HelpCircle } from 'lucide-react';

interface MioloProps {
  onSelectionChange?: (hasItems: boolean) => void;
  onValidateResult?: (isCorrect: boolean) => void;
  status?: "IDLE" | "CORRECT" | "WRONG";
  unidadeAtiva?: string;
}

const traducoesAbas: Record<string, Record<string, string>> = {
  es: {
    instrucao: "Selecciona la opción contextual más adecuada:",
    validando: "Analizando respuesta...",
    validar: "Validar Respuesta",
    refazer: "Intentar de nuevo",
    aguardando: "Cargando desafío..."
  },
  en: {
    instrucao: "Select the most appropriate contextual option:",
    validando: "Analyzing response...",
    validar: "Validate Answer",
    refazer: "Try Again",
    aguardando: "Loading challenge..."
  },
  pt: {
    instrucao: "Selecione a opção contextual mais adequada:",
    validando: "Analisando resposta...",
    validar: "Validar Resposta",
    refazer: "Tentar de Novo",
    aguardando: "Carregando desafio..."
  }
};

export default function MioloMultiplaEscolha({ 
  onSelectionChange,
  onValidateResult,
  status = "IDLE",
  unidadeAtiva
}: MioloProps) {
  const [selecionado, setSelecionado] = useState<string | null>(null);
  const [options, setOptions] = useState<string[]>([]);
  const [correctOption, setCorrectOption] = useState<string>("");
  const [pergunta, setPergunta] = useState<string>("Carregando enunciado...");
  
  const [localStatus, setLocalStatus] = useState<'IDLE' | 'CORRECT' | 'WRONG'>('IDLE');
  const [idiomaNativoAluno, setIdiomaNativoAluno] = useState("Español");
  const [feedbackIA, setFeedbackIA] = useState("");
  const [analisando, setAnalisando] = useState(false);
  const [carregando, setCarregando] = useState(true);

  const GEMINI_API_KEY = "AQ.Ab8RN6KKu4ManOw3IOPNh9Ls34APH0N-BrWxsNBRlmUI4pFBAw";
  const USER_ID_ALVO = "b1b1b1b1-b1b1-b1b1-b1b1-b1b1b1b1b1b1";

  const obterLangKey = () => {
    const lang = idiomaNativoAluno?.toLowerCase() || "";
    if (lang.includes("eng") || lang.includes("ing")) return "en";
    if (lang.includes("por") || lang.includes("bra")) return "pt";
    return "es";
  };

  const t = traducoesAbas[obterLangKey()];

  const gerarMultiplaEscolhaComIA = async () => {
    try {
      const prompt = `Gere uma questão avançada de múltipla escolha para interpretação e gramática em português relacionada à unidade pedagógica "${unidadeAtiva || "O Labirinto dos Passados Irregulares"}". Retorne estritamente um objeto JSON com três chaves: "enunciado" (a pergunta ou contexto claro), "correta" (a resposta certa) e "opcoes" (uma lista contendo a resposta correta e mais 3 distratores gramaticais plausíveis). Exemplo: {"enunciado": "Escolha a forma correta do verbo no pretérito perfeito:", "correta": "Ele fez o dever ontem.", "opcoes": ["Ele fez o dever ontem.", "Ele fizeu o dever.", "Ele fazeou o dever ontem.", "Ele tinha fazido."]}. Não envie blocos de markdown, envie apenas o JSON bruto.`;
      
      const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${GEMINI_API_KEY}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
      });

      if (res.ok) {
        const data = await res.json();
        const textoBruto = data?.candidates?.[0]?.content?.parts?.[0]?.text || "";
        const jsonLimpo = textoBruto.replace(/```json/g, "").replace(/```/g, "").trim();
        const obj = JSON.parse(jsonLimpo);
        if (obj.enunciado && obj.correta && obj.opcoes) {
          return obj;
        }
      }
    } catch (e) {}
    return {
      enunciado: "Selecione a alternativa correta que preenche a lacuna gramatical: 'Se eu ______ as chaves, teria entrado antes.'",
      correta: "tivesse trazido",
      opcoes: ["tivesse trazido", "tivesse trago", "tivesse trazido-as", "tivera trazendo"]
    };
  };

  useEffect(() => {
    async function carregarMultiplaEscolhaDoBanco() {
      try {
        setCarregando(true);
        
        // Puxar idioma nativo do aluno para adequação contextual
        const { data: userDados } = await supabase.from('users').select('native_language').eq('id', USER_ID_ALVO);
        if (userDados && userDados.length > 0) {
          setIdiomaNativoAluno(userDados[0].native_language || "Español");
        }

        const nomeUnidade = unidadeAtiva || 'O Labirinto dos Passados Irregulares';
        const { data: dados, error } = await supabase
          .from('exercises')
          .select('*')
          .eq('unit', nomeUnidade)
          .eq('activity_type', 3)
          .limit(1);

        if (error) throw error;

        let exe = null;
        if (dados && dados.length > 0) exe = dados[0];

        if (!exe) {
          exe = await gerarMultiplaEscolhaComIA();
        }

        setPergunta(exe.reading_text || exe.enunciado || "Selecione a resposta correta:");
        const respostaCerta = exe.correct_answer || exe.correta || "";
        setCorrectOption(respostaCerta);

        let erradas: string[] = [];
        const altOpts = exe.alternative_options || exe.opcoes;
        if (altOpts) {
          if (Array.isArray(altOpts)) {
            erradas = altOpts;
          } else if (typeof altOpts === 'string') {
            try {
              erradas = JSON.parse(altOpts);
            } catch (e) {
              erradas = altOpts.split(',').map((s: string) => s.trim());
            }
          }
        }

        const todasOpcoes = respostaCerta 
          ? Array.from(new Set([respostaCerta, ...erradas])).sort(() => Math.random() - 0.5)
          : erradas.sort(() => Math.random() - 0.5);

        setOptions(todasOpcoes);
        setLocalStatus('IDLE');
        setSelecionado(null);
        setFeedbackIA("");
      } catch (err) {
        console.error("Erro na Central Cliente (Múltipla Escolha):", err);
      } finally {
        setCarregando(false);
      }
    }
    carregarMultiplaEscolhaDoBanco();
  }, [unidadeAtiva]);

  useEffect(() => {
    if (status === "IDLE") {
      setLocalStatus("IDLE");
      setSelecionado(null);
      setFeedbackIA("");
    }
  }, [status]);

  const handleSelect = (opcao: string) => {
    if (localStatus === "CORRECT" || analisando) return; 
    try {
      const AudioContext = window.AudioContext || (window as any).webkitAudioContext;
      if (AudioContext) {
        const ctx = new AudioContext();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.frequency.setValueAtTime(1020, ctx.currentTime);
        gain.gain.setValueAtTime(0.02, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.03);
        osc.start(); osc.stop(ctx.currentTime + 0.03);
      }
    } catch (e) {}
    setSelecionado(opcao);
    setLocalStatus('IDLE');
    if (onSelectionChange) onSelectionChange(true);
  };

  const executarValidacaoInterna = async () => {
    if (!selecionado || analisando) return;

    setAnalisando(true);
    setFeedbackIA("");

    try {
      const prompt = `Analise a resposta do aluno em uma questão de múltipla escolha. Enunciado: "${pergunta}". Opção selecionada pelo aluno: "${selecionado}". Resposta correta esperada: "${correctOption}".
      Responda estritamente em formato JSON com duas chaves:
      1) "valido": true ou false.
      2) "feedback": Uma justificativa pedagógica curtíssima (máximo 10 palavras) explicando o erro ou confirmando o acerto. Escreva na língua nativa do aluno: ${idiomaNativoAluno}.`;

      const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${GEMINI_API_KEY}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
      });

      if (res.ok) {
        const data = await res.json();
        const textoBruto = data?.candidates?.[0]?.content?.parts?.[0]?.text || "";
        const jsonLimpo = textoBruto.replace(/```json/g, "").replace(/```/g, "").trim();
        const resultadoIA = JSON.parse(jsonLimpo);

        const acertou = resultadoIA.valido === true;
        setLocalStatus(acertou ? 'CORRECT' : 'WRONG');
        setFeedbackIA(resultadoIA.feedback || "");
        
        if (onValidateResult) onValidateResult(acertou);
      } else {
        const acertou = selecionado === correctOption;
        setLocalStatus(acertou ? 'CORRECT' : 'WRONG');
        setFeedbackIA(acertou ? "Excelente!" : "Incorreto.");
        if (onValidateResult) onValidateResult(acertou);
      }
    } catch (e) {
      const acertou = selecionado === correctOption;
      setLocalStatus(acertou ? 'CORRECT' : 'WRONG');
    } finally {
      setAnalisando(false);
    }
  };

  const resetarExercicio = () => {
    setSelecionado(null);
    setLocalStatus('IDLE');
    setFeedbackIA("");
  };

  if (carregando) {
    return (
      <div className="w-full text-center py-8 text-cyan-400 font-bold animate-pulse text-xs tracking-widest uppercase">
        {t?.aguardando || "CARREGANDO..."}
      </div>
    );
  }

  const exibirContainerInferior = (localStatus === 'IDLE' && selecionado !== null) || analisando || feedbackIA;

  return (
    <div className="w-full h-full flex flex-col justify-between text-left font-sans overflow-hidden select-none gap-2 p-1 flex-1 min-h-0">
      
      {/* 1. INSTRUÇÃO COMPACTA */}
      <div className="flex items-center gap-1.5 shrink-0">
        <HelpCircle size={13} className="text-cyan-400 shrink-0" />
        <span className="text-[clamp(10px,1.2vw,12px)] font-bold text-cyan-400 uppercase tracking-wider block">
          {t.instrucao}
        </span>
      </div>

      {/* 2. CARD DO ENUNCIADO FLUIDO */}
      <div className="w-full bg-[#070d19]/80 border border-white/[0.03] rounded-xl p-2.5 flex items-center justify-center shrink-0">
        <p className="text-[clamp(12px,1.4vw,15px)] font-bold leading-normal text-center text-slate-200 w-full break-words">
          {pergunta}
        </p>
      </div>

      {/* 3. GRID DE OPÇÕES RESPONSIVO ANTI-SCROLL (2 COLUNAS DE ALTA DENSIDADE) */}
      <div className="grid grid-cols-2 gap-2 w-full flex-1 min-h-0 items-center content-center overflow-hidden">
        {options.map((opcao, idx) => {
          const isThisSelected = selecionado === opcao;
          let optStyle = "border-slate-800/80 bg-[#04111C]/30 text-slate-300 hover:bg-[#1C3B50]/10";
          
          if (isThisSelected) {
            if (localStatus === 'CORRECT') optStyle = "border-emerald-500 bg-emerald-950/20 text-emerald-400 font-black";
            else if (localStatus === 'WRONG') optStyle = "border-rose-500 bg-rose-950/20 text-rose-400 font-black";
            else optStyle = "border-cyan-400 bg-cyan-950/30 text-cyan-400 font-black ring-1 ring-cyan-400/20";
          }

          return (
            <button
              key={idx}
              type="button"
              disabled={localStatus === "CORRECT" || analisando}
              onClick={() => handleSelect(opcao)}
              className={`w-full text-center py-2 px-3 rounded-lg border text-[clamp(11px,1.3vw,13px)] font-medium transition-all cursor-pointer flex items-center justify-center min-h-[42px] leading-snug ${optStyle}`}
            >
              {opcao}
            </button>
          );
        })}
      </div>

      {/* 4. SEÇÃO DE SUBMISSÃO E FEEDBACKS DA MENTORA IA (COMPACTA E DINÂMICA) */}
      {exibirContainerInferior && (
        <div className="w-full shrink-0 flex flex-col justify-end mt-0.5 animate-fade-in">
          {localStatus === 'IDLE' && selecionado !== null && !analisando && (
            <button
              onClick={executarValidacaoInterna}
              className="w-full py-2 bg-gradient-to-r from-cyan-600 to-cyan-700 text-white rounded-xl font-black text-[clamp(11px,1.3vw,14px)] uppercase tracking-widest cursor-pointer flex items-center justify-center gap-2"
            >
              <Send size={11} /> {t.validar}
            </button>
          )}

          {analisando && (
            <div className="text-[11px] text-cyan-400 font-bold tracking-widest text-center py-2 uppercase flex items-center justify-center gap-2 bg-cyan-950/10 border border-cyan-500/10 rounded-xl animate-pulse">
              <Sparkles size={12} className="animate-spin text-cyan-400" /> <span>{t.validando}</span>
            </div>
          )}

          {localStatus === 'CORRECT' && feedbackIA && (
            <div className="flex flex-col items-center text-center bg-emerald-950/20 border border-emerald-500/20 py-1.5 px-2 rounded-lg animate-fade-in">
              <div className="flex items-center gap-1 text-emerald-400 text-[10px] font-black uppercase tracking-wider">
                <CheckCircle size={12} /> <span>Excelente!</span>
              </div>
              <p className="text-[11px] text-slate-300 font-medium italic truncate max-w-full">"{feedbackIA}"</p>
            </div>
          )}

          {localStatus === 'WRONG' && feedbackIA && (
            <div className="flex flex-col items-center gap-0.5 text-center bg-rose-950/20 border border-rose-500/20 py-1.5 px-2 rounded-lg animate-fade-in">
              <div className="flex items-center gap-1 text-rose-400 text-[10px] font-black uppercase tracking-wider">
                <XCircle size={12} /> <span>Ajuste necessário</span>
              </div>
              <div className="flex items-center justify-between w-full gap-2">
                <p className="text-[11px] text-slate-300 font-medium italic truncate flex-1 text-left">"{feedbackIA}"</p>
                <button 
                  onClick={resetarExercicio}
                  className="px-2 py-0.5 bg-slate-900 border border-white/[0.05] text-slate-200 text-[9px] uppercase font-black rounded-md cursor-pointer shrink-0"
                >
                  <RefreshCw size={10} />
                </button>
              </div>
            </div>
          )}
        </div>
      )}

    </div>
  );
}
