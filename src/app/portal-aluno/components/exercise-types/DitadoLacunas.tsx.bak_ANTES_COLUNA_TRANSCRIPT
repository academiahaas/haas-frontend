'use client';
import React, { useState, useEffect, useRef } from 'react';
import { Volume2, CheckCircle, XCircle } from 'lucide-react';
import { supabase } from '@/lib/supabase';

interface DitadoLacunasProps {
  onSelectionChange?: (hasItems: boolean) => void;
  onValidateResult?: (isCorrect: boolean) => void;
  status?: 'IDLE' | 'CORRECT' | 'WRONG';
  unidadeAtiva?: string;
}

export default function DitadoLacunas({ 
  onSelectionChange, 
  onValidateResult, 
  status: propStatus = 'IDLE', 
  unidadeAtiva 
}: DitadoLacunasProps) {
  const [inputValue, setInputValue] = useState("");
  const [localStatus, setLocalStatus] = useState<'IDLE' | 'CORRECT' | 'WRONG'>('IDLE');
  const inputRef = useRef<HTMLInputElement>(null);

  const [fraseEstruturada, setFraseEstruturada] = useState<string>("");
  const [audioUrl, setAudioUrl] = useState("");
  const [targetWord, setTargetWord] = useState("");

  useEffect(() => {
    if (propStatus === 'IDLE') {
      setInputValue('');
      setLocalStatus('IDLE');
    } else {
      setLocalStatus(propStatus);
    }
  }, [propStatus]);

  useEffect(() => {
    async function carregarDitadoDoBanco() {
      try {
        const nomeUnidade = unidadeAtiva || "O Labirinto dos Passados Irregulares";
        
        const { data: dados, error } = await supabase
          .from('exercises')
          .select('*')
          .eq('unit', nomeUnidade)
          .eq('activity_type', 4);

        if (error) throw error;
        
        if (dados && dados.length > 0) {
          // Voltou ao fluxo dinâmico padrão (dados[0])
          const exe = dados[0];
          
          setTargetWord(exe.correct_answer || "");
          setFraseEstruturada(exe.reading_text || "");
          
          // FORÇA A CAPTURA EXCLUSIVA DA COLUNA AUDIO_URL
          const linkAudioBanco = exe.audio_url || "";
          setAudioUrl(linkAudioBanco);
          
          // LOG DE AUDITORIA NO CONSOLE DO NAVEGADOR
          console.log(`%c 🎵 [HAAS AUDIO] Exercício ID: ${exe.id} | Link do Supabase:`, "background: #0284c7; color: white; padding: 2px 6px; rounded: 4px;", linkAudioBanco);
        }
      } catch (err) {
        console.error("Erro na Central Cliente (Ditado Prático):", err);
      }
    }
    carregarDitadoDoBanco();
  }, [unidadeAtiva]);

  useEffect(() => {
    if (inputRef.current && fraseEstruturada) inputRef.current.focus();
  }, [fraseEstruturada]);

  const playAudio = () => {
    if (!audioUrl) {
      console.warn("⚠️ [HAAS AUDIO] Tentativa de reprodução abortada: coluna 'audio_url' está vazia para este exercício no Supabase.");
      return;
    }

    try {
      // Pequeno bip de feedback de clique mantido
      const AudioContext = window.AudioContext || (window as any).webkitAudioContext;
      if (AudioContext) {
        const ctx = new AudioContext();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine'; osc.frequency.setValueAtTime(1020, ctx.currentTime);
        gain.gain.setValueAtTime(0.02, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.03);
        osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.03);
      }
    } catch (e) {}

    // EXECUÇÃO DO ÁUDIO REAL OBRIGATÓRIA DA CENTRAL
    const audio = new Audio(audioUrl);
    audio.play().catch(err => {
      console.error("❌ [HAAS AUDIO] O link do Supabase falhou ao reproduzir ou o arquivo está inacessível:", err);
    });
  };

  const handleInputChange = (val: string) => {
    setInputValue(val);
    if (onSelectionChange) onSelectionChange(val.trim().length > 0);
  };

  const handleVerificar = () => {
    if (localStatus !== 'IDLE' || !inputValue.trim()) return;
    
    const acertou = inputValue.trim().toLowerCase() === targetWord.toLowerCase();
    
    if (acertou) {
      setLocalStatus('CORRECT');
    } else {
      setLocalStatus('WRONG');
      setTimeout(() => {
        setInputValue('');
        setLocalStatus('IDLE');
        if (inputRef.current) inputRef.current.focus();
      }, 1500);
    }

    if (onValidateResult) {
      onValidateResult(acertou);
    }
  };

  const partesDaFrase = fraseEstruturada.split(/______+/);
  const prefixo = partesDaFrase[0] || "";
  const sufixo = partesDaFrase[1] || "";

  return (
    <div className="w-full h-full flex flex-col justify-between items-stretch text-left animate-fade-in font-mono flex-1 min-h-0 gap-4">
      <div className="flex items-center gap-4 shrink-0 bg-[#070d19]/40 p-3 rounded-xl border border-white/[0.02]">
        <button 
          onClick={playAudio} 
          className="p-4 bg-[#0c192e] hover:bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 rounded-2xl transition-all duration-150 cursor-pointer active:scale-95 shadow-[0_4px_15px_rgba(0,255,255,0.05)] shrink-0"
        >
          <Volume2 size={24} className="animate-pulse" />
        </button>
        <span className="text-[clamp(11px,3.2vw,13px)] font-black text-slate-400 uppercase tracking-wider leading-snug">
          Clique no <span className="text-cyan-400">alto-falante</span> para escutar e digite a palavra ausente
        </span>
      </div>

      <div className="bg-[#0c192e] border border-white/[0.04] rounded-xl py-6 px-4 text-center text-[clamp(14px,3.8vw,16px)] font-bold text-slate-300 leading-relaxed flex flex-wrap items-center justify-center gap-x-2 gap-y-3 flex-1 min-h-0 w-full overflow-y-auto">
        <span className="font-sans font-medium text-[#F8FAFC]">{prefixo}</span>
        <input
          ref={inputRef}
          type="text"
          value={inputValue}
          disabled={localStatus === 'CORRECT'}
          onChange={(e) => handleInputChange(e.target.value)}
          onKeyDown={(e) => e.key === 'Enter' && handleVerificar()}
          placeholder="???"
          className={`bg-[#070d19] border-2 rounded-xl px-3 py-1.5 text-center font-black tracking-wide text-[clamp(14px,4vw,16px)] w-32 transition-all focus:outline-none focus:border-[#f59e0b]/50 ${
            localStatus === 'CORRECT' ? 'border-[#00E676] text-[#00E676]' : localStatus === 'WRONG' ? 'border-red-500 text-red-500' : 'border-white/[0.08] text-[#f59e0b]'
          }`}
        />
        <span className="font-sans font-medium text-[#F8FAFC]">{sufixo}</span>
      </div>

      <div className="w-full shrink-0 mt-auto min-h-[50px] flex items-center justify-center">
        {localStatus === 'IDLE' && (
          <button 
            onClick={handleVerificar}
            className="w-full py-4 bg-[#070d19] hover:bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 font-black text-[clamp(12px,3.5vw,14px)] uppercase tracking-widest rounded-xl transition-all duration-200 cursor-pointer"
          >
            Verificar Resposta (Enter)
          </button>
        )}

        {localStatus === 'CORRECT' && (
          <div className="flex items-center justify-center gap-2 text-[#00E676] text-[clamp(12px,3.5vw,14px)] font-black uppercase tracking-wider animate-bounce w-full text-center py-2">
            <CheckCircle size={16} /> <span>Excelente! Escuta e grafia perfeitas.</span>
          </div>
        )}

        {localStatus === 'WRONG' && (
          <div className="flex items-center justify-center gap-2 text-red-500 text-[clamp(12px,3.5vw,14px)] font-black uppercase tracking-wider animate-pulse w-full text-center py-2">
            <XCircle size={16} /> <span>Incorreto. Ouça novamente e ajuste a digitação!</span>
          </div>
        )}
      </div>
    </div>
  );
}
