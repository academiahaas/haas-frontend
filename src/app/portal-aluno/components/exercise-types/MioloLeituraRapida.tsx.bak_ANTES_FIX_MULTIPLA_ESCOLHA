'use client';
import React, { useState, useEffect, useRef } from 'react';
import { Timer, FileText } from 'lucide-react';
import { supabase } from '@/lib/supabase';

interface MioloLeituraRapidaProps {
  onSelectionChange?: (hasItems: boolean) => void;
  onValidateResult?: (isCorrect: boolean) => void;
  status?: 'IDLE' | 'CORRECT' | 'WRONG';
  unidadeAtiva?: string;
}

export default function MioloLeituraRapida({
  onSelectionChange,
  onValidateResult,
  status = 'IDLE',
  unidadeAtiva
}: MioloLeituraRapidaProps) {
  const [textoLongo, setTextoLongo] = useState("Carregando parágrafo de interpretação...");
  const [textoGabarito, setTextoGabarito] = useState("");
  const [inputValue, setInputValue] = useState("");
  const [nivelExercicio, setNivelExercicio] = useState("A2");
  
  const [timeLeft, setTimeLeft] = useState(30);
  const [fase, setFase] = useState<'LEITURA' | 'DIGITACAO'>('LEITURA');
  const timerRef = useRef<any>(null);
  const inputRef = useRef<HTMLTextAreaElement>(null);

  useEffect(() => {
    async function carregarLeituraDoBanco() {
      try {
        const nomeUnidade = unidadeAtiva || "O Labirinto dos Passados Irregulares";
        
        const { data: dados, error } = await supabase
          .from('exercises')
          .select('*')
          .eq('unit', nomeUnidade)
          .eq('activity_type', 6);

        if (error) throw error;

        if (dados && dados.length > 0) {
          const exe = dados[0];
          const textoBase = exe.reading_text || exe.correct_answer || "";
          
          setTextoLongo(textoBase);
          setTextoGabarito(textoBase.trim());
          setNivelExercicio(exe.level || "A2");
          setInputValue("");
          setFase('LEITURA');
          setTimeLeft(30);
        }
      } catch (err) {
        console.error("Erro ao carregar Tipo 6 do Supabase:", err);
      }
    }
    carregarLeituraDoBanco();
  }, [unidadeAtiva]);

  useEffect(() => {
    if (status !== 'IDLE') {
      clearInterval(timerRef.current);
      return;
    }

    timerRef.current = setInterval(() => {
      setTimeLeft((prev) => {
        if (prev <= 1) {
          if (fase === 'LEITURA') {
            setFase('DIGITACAO');
            return 60;
          }
          clearInterval(timerRef.current);
          return 0;
        }
        return prev - 1;
      });
    }, 1000);

    return () => clearInterval(timerRef.current);
  }, [fase, status]);

  useEffect(() => {
    if (fase === 'DIGITACAO' && inputRef.current) {
      inputRef.current.focus();
    }
  }, [fase]);

  useEffect(() => {
    if (status === 'IDLE' && fase === 'DIGITACAO') {
      setInputValue("");
      setFase('LEITURA');
      setTimeLeft(30);
    }
  }, [status]);

  const playAudio = () => {
    if (typeof window !== 'undefined' && 'speechSynthesis' in window && textoGabarito) {
      window.speechSynthesis.cancel();
      
      const utterance = new SpeechSynthesisUtterance(textoGabarito);
      utterance.lang = 'pt-BR';
      
      // ESCALA DE VELOCIDADE CALIBRADA
      let velocidade = 1.25; 
      const nivel = nivelExercicio.toUpperCase().trim();
      
      if (nivel.startsWith("A1")) velocidade = 1.10;
      else if (nivel.startsWith("A2")) velocidade = 1.25;
      else if (nivel.startsWith("B1") || nivel.startsWith("B2")) velocidade = 1.35;
      else if (nivel.startsWith("C1") || nivel.startsWith("C2")) velocidade = 1.45;
      
      utterance.rate = velocidade;
      window.speechSynthesis.speak(utterance);
    }
  };

  const handleInputChange = (val: string) => {
    setInputValue(val);
    if (onSelectionChange) onSelectionChange(val.trim().length > 0);

    const respostaAluno = val.trim().toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()]/g, "");
    const gabaritoComparacao = textoGabarito.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()]/g, "");
    
    const acertou = respostaAluno === gabaritoComparacao;
    if (onValidateResult) onValidateResult(acertou);
  };

  return (
    <div className="w-full h-full flex flex-col justify-between items-stretch text-left animate-fade-in font-mono flex-1 min-h-0 gap-4">
      <div className="flex items-center justify-between shrink-0 bg-[#070d19]/60 p-3 rounded-xl border border-white/[0.02]">
        <button 
          onClick={playAudio}
          className="px-4 py-2 bg-[#0c192e] hover:bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 font-black text-xs uppercase tracking-wider rounded-xl transition-all cursor-pointer active:scale-95 flex items-center gap-2"
        >
          <FileText size={14} />
          <span>Ouvir Texto ({nivelExercicio})</span>
        </button>
        <div className={`flex items-center gap-1.5 px-3 py-1 rounded-lg border font-black text-xs ${
          timeLeft <= 10 ? 'text-red-500 border-red-500/20 bg-red-500/5 animate-pulse' : 'text-[#f59e0b] border-[#f59e0b]/20 bg-[#f59e0b]/5'
        }`}>
          <Timer size={14} />
          <span>{timeLeft}s</span>
        </div>
      </div>

      <div className="bg-[#0c192e] border border-white/[0.04] rounded-xl p-4 text-[clamp(13px,3.6vw,15px)] font-medium text-slate-300 leading-relaxed flex-1 min-h-0 overflow-y-auto w-full">
        <p className="font-sans text-[#F8FAFC] text-justify">{textoLongo}</p>
      </div>

      <div className="w-full shrink-0 flex flex-col gap-2">
        {fase === 'LEITURA' ? (
          <button
            onClick={() => { setFase('DIGITACAO'); setTimeLeft(60); }}
            className="w-full py-3.5 bg-gradient-to-r from-cyan-600 to-cyan-700 text-white font-black text-xs uppercase tracking-widest rounded-xl shadow-md cursor-pointer transition-all active:scale-95 text-center"
          >
            Ir para a digitação
          </button>
        ) : (
          <textarea
            ref={inputRef}
            value={inputValue}
            disabled={status === 'CORRECT'}
            onChange={(e) => handleInputChange(e.target.value)}
            placeholder="Digite o parágrafo acima com precisão para validar..."
            className={`w-full h-24 bg-[#070d19] border-2 rounded-xl p-3 font-sans text-sm text-slate-200 transition-all focus:outline-none focus:border-cyan-500/50 resize-none ${
              status === 'CORRECT' ? 'border-[#00E676] text-[#00E676]' : status === 'WRONG' ? 'border-red-500 text-red-500' : 'border-white/[0.08]'
            }`}
          />
        )}
      </div>
    </div>
  );
}
