export default function PortalAluno() {
  const router = useRouter();
  const [idioma, setIdioma] = useState<'PT' | 'ES' | 'EN'>('PT');
  const t = traducoes[idioma];
  const blocosXP = Array.from({ length: 10 }, (_, i) => i < 8);
  const [dadosRadar] = useState([
    { competenca: 'Fala', nota: 95 }, { competenca: 'Escuta', nota: 88 }, { competenca: 'Gramática', nota: 90 }, { competenca: 'Escrita', nota: 62 }, { competenca: 'Leitura', nota: 78 },
  ]);
  const [showTooltip, setShowTooltip] = useState(false);
  const [mousePos, setMousePos] = useState({ x: 0, y: 0 });
  const [mounted, setMounted] = useState(false);

  useEffect(() => {
    setMounted(true);
    const salvo = localStorage.getItem('haas_idioma_auxiliar');
    if (salvo && (salvo === 'PT' || salvo === 'ES' || salvo === 'EN')) {
      setIdioma(salvo);
    }
  }, []);

  const mudarIdioma = (lang: 'PT' | 'ES' | 'EN') => {
    setIdioma(lang);
    localStorage.setItem('haas_idioma_auxiliar', lang);
  };

  const handleMouseMove = (e: React.MouseEvent) => {
    const rect = e.currentTarget.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width - 0.5;
    const y = (e.clientY - rect.top) / rect.height - 0.5;
    setMousePos({ x, y });
  };

  return (
    <div className="min-h-screen bg-[#111e2d] text-slate-200 font-sans antialiased p-4 flex flex-col lg:flex-row gap-4">
      
      {/* COLUMN 1: SIDEBAR ESQUERDA (AVATAR PREMIUM + COELHO ROBÓTICO) */}
      <aside 
        className="w-full lg:w-64 bg-[#16273c] border border-[#233854] rounded-2xl p-4 flex flex-col gap-4 shadow-2xl shrink-0"
        onMouseMove={handleMouseMove}
        onMouseLeave={() => { setMousePos({ x: 0, y: 0 }); setShowTooltip(false); }}
      >
        <div className="flex items-center gap-2.5">
          <div className="w-6 h-6 rounded-full bg-cyan-500/20 border border-cyan-500/40 flex items-center justify-center text-xs">🎧</div>
          <h1 className="text-sm font-black tracking-wider text-slate-200 font-mono uppercase">HAAS IDIOMAS</h1>
        </div>

        {/* SELECTOR DE IDIOMA */}
        <div className="bg-[#0b1420] p-0.5 rounded-xl border border-[#233854] flex gap-0.5">
          {['PT', 'ES', 'EN'].map((l) => (
            <button key={l} onClick={() => mudarIdioma(l)} className={`flex-1 text-[9px] font-black py-1.5 rounded-lg transition-all cursor-pointer ${idioma === l ? 'bg-[#10b981] text-slate-950 font-black shadow-md' : 'text-slate-400 hover:text-white'}`}>{l}</button>
          ))}
        </div>

        {/* CARD AVATAR ALUNO */}
        <div className="bg-[#0b1420] border border-[#233854] rounded-xl p-4 text-center relative">
          <div className="w-16 h-16 bg-gradient-to-tr from-amber-500 to-orange-400 rounded-full mx-auto flex items-center justify-center text-xl relative border-2 border-[#16273c] shadow-lg">
            👨‍🚀
            <div className="absolute -bottom-1 -right-1 bg-indigo-600 text-[8px] font-black text-white h-4 w-4 rounded-full flex items-center justify-center border border-[#0b1420]">B2</div>
          </div>
          <h3 className="mt-2.5 text-xs font-black text-white uppercase tracking-wide">Aluno Teste</h3>
          <p className="text-[9px] text-slate-400 font-black uppercase tracking-wider">Nível B1 Intermediário</p>
          
          <div className="mt-3 text-left bg-[#16273c]/60 p-2 rounded-lg border border-[#233854]/30">
            <div className="flex justify-between text-[8px] font-mono font-black text-slate-400">
              <span>XP: 2.450 / 3.000</span>
              <span className="text-amber-500 font-black">(81% para B2)</span>
            </div>
            <div className="flex gap-0.5 h-1.5 mt-1">
              {blocosXP.map((ativo, idx) => (
                <div key={idx} className={`flex-1 rounded-full ${ativo ? 'bg-amber-500 shadow-sm shadow-amber-500/50' : 'bg-slate-800'}`} />
              ))}
            </div>
          </div>
        </div>

        {/* MEDALHAS FLOTANTES INTERATIVAS */}
        <div className="flex justify-center gap-1.5 py-1 text-sm bg-[#0b1420]/30 rounded-xl border border-[#233854]/20 animate-pulse">
          <span>🔥</span><span>🔮</span><span>🌟</span><span>🏆</span><span>🛡️</span>
